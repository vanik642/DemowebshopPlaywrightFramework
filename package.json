{
  "name": "playwrightautomationframework",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:critical": "playwright test --grep @critical",
    "test:no-flaky": "playwright test --grep-invert @smoke",
    "test:shopping": " npx playwright test tests/shoppingCart.spec.ts ",
    "test:search": " npx playwright test tests/search.spec.ts ",
    "test:stage": " npx playwright test tests/productInfo.spec.ts --config=playwright.config.stage.ts",
    "test:prod": " npx playwright test tests/productInfo.spec.ts --config=playwright.config.prod.ts",
    "lint": "eslint . --ext .ts,.js --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "lint:report": "eslint . --ext .ts,.js -f html -o eslint-report/index.html || true",
    "lint:report:json": "eslint . --ext .ts,.js -f json -o eslint-report/eslint-results.json || true",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.6.0"
  }
}
